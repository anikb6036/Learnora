# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Required for sending real emails via Resend
RESEND_API_KEY=

# SENDER_EMAIL: If you verified a domain in Resend, put your verified sender email here (e.g. admissions@yourdomain.com)
# Defaults to admissions@learnora.in
SENDER_EMAIL="admissions@learnora.in"

# SENDER_NAME: Custom display name for the sender
SENDER_NAME="Learnora Admissions"

# Razorpay Credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
